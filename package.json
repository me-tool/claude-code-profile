{
  "name": "claude-code-profile",
  "version": "0.2.0",
  "description": "Chrome-like profile management for Claude Code",
  "type": "module",
  "bin": {
    "ccp": "dist/ccp.js"
  },
  "scripts": {
    "dev": "tsx bin/ccp.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["claude", "claude-code", "profile", "cli", "ccp"],
  "license": "MIT",
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/me-tool/claude-code-profile.git"
  },
  "homepage": "https://github.com/me-tool/claude-code-profile#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "fs-extra": "^11.2.0",
    "simple-git": "^3.27.0",
    "tar": "^7.4.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "tsup": {
    "entry": ["bin/ccp.ts"],
    "format": ["esm"],
    "dts": false,
    "clean": true,
    "target": "node18",
    "splitting": false,
    "bundle": true,
    "external": ["simple-git"]
  }
}
